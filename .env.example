# Environment Configuration
NODE_ENV=development
PYTHON_ENV=development

# API Configuration
API_HOST=localhost
API_PORT=8000
API_BASE_URL=http://localhost:8000

# Database Configuration
DATABASE_URL=sqlite:///./personal_ai_system.db
REDIS_URL=redis://localhost:6379

# AI Model Configuration
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Quantum Computing Configuration
QISKIT_API_TOKEN=your_qiskit_token_here

# Security
SECRET_KEY=your_secret_key_here_generate_a_strong_one
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Mirror System Configuration
MIRROR_PERSONAS_ENABLED=true
QUANTUM_PREP_ENABLED=true
NAVIER_STOKES_WARMUP=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/personal_ai_system.log

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WEBSOCKET_URL=ws://localhost:8000/ws